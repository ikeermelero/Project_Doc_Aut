      color: var(--accent);
    }

    .doc-content pre {
      background: rgba(0,0,0,0.4);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      overflow-x: auto;
      margin: 0.75rem 0;
    }

    .doc-content ul, .doc-content ol { padding-left: 1.5rem; }

    .doc-content strong { color: var(--accent2); }

