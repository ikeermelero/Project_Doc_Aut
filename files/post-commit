      gap: 0.4rem;
      margin-top: 0.75rem;
    }

    .file-tag {
      font-family: var(--mono);
      font-size: 0.72rem;
      background: rgba(124,58,237,0.12);
      color: #a78bfa;
      border: 1px solid rgba(124,58,237,0.25);
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
    }

    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: var(--muted);
    }

    .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }
    .empty-state p { font-family: var(--mono); font-size: 0.9rem; }

    footer {
      text-align: center;
      padding: 2rem;
      color: var(--muted);
      font-size: 0.75rem;
      font-family: var(--mono);
      border-top: 1px solid var(--border);
      margin-top: 3rem;
    }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <div class="logo-badge">⚡ git-ollama-docs</div>
      <h1 id="project-title">Documentación del Proyecto</h1>
      <p class="subtitle" id="project-subtitle">Generada automáticamente con Ollama · phi3</p>
    </div>
  </header>

  <main>
    <div id="log-container">
      <div class="empty-state">
        <div class="icon">📋</div>
        <p>Aún no hay entradas. Haz un commit para generar documentación.</p>
      </div>
    </div>
  </main>

  <footer>
    Generado por git-ollama-docs · <span id="footer-date"></span>
  </footer>

  <script>
    document.getElementById('footer-date').textContent = new Date().toLocaleDateString('es-ES');
  </script>
</body>
</html>
HTML_TEMPLATE

    echo -e "${GREEN}  ✓ Archivo HTML creado en ${DOCS_PATH}${RESET}"
else
    echo -e "${GREEN}  ✓ ${DOCS_PATH} ya existe${RESET}"
fi

echo ""

# ── 5. Construir prompt optimizado para phi3 ─────────────────
echo -e "${BLUE}▶ Preparando prompt para phi3...${RESET}"

PROMPT="Eres un asistente técnico que documenta cambios en proyectos de software. Responde SIEMPRE en español. Sé conciso y directo.

Documenta este commit en formato HTML (solo el contenido interno, sin etiquetas html/head/body):

Proyecto: ${PROJECT_NAME}
Commit: ${COMMIT_HASH}
Mensaje: ${COMMIT_MSG}
Archivos modificados: ${COMMIT_FILES}
Estadísticas: ${COMMIT_STATS}

Genera una sección de documentación con:
1. Un resumen del cambio (2-3 frases)
2. Qué se modificó y por qué (lista breve)
3. Impacto técnico (si aplica)

Usa etiquetas HTML simples: <p>, <ul>, <li>, <strong>, <code>. Sin markdown."

echo -e "${GREEN}  ✓ Prompt preparado (optimizado para velocidad)${RESET}"
echo ""

# ── 6. Llamar a Ollama con streaming ─────────────────────────
echo -e "${BLUE}▶ Enviando a Ollama ${BOLD}${OLLAMA_MODEL}${RESET}${BLUE}...${RESET}"
echo -e "${DIM}  (Generando documentación, puede tardar unos segundos)${RESET}"
echo ""
echo -e "${MAGENTA}┌─ Respuesta de Ollama ─────────────────────────────${RESET}"

OLLAMA_RESPONSE=""
SPINNER_CHARS="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
SPINNER_IDX=0

# Llamada a Ollama con parámetros optimizados para velocidad
RESPONSE_RAW=$(curl -s --max-time 120 \
  -X POST "${OLLAMA_URL}" \
  -H "Content-Type: application/json" \
  -d "{
    \"model\": \"${OLLAMA_MODEL}\",
    \"prompt\": $(echo "$PROMPT" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'),
    \"stream\": false,
    \"options\": {
      \"num_predict\": 400,
      \"temperature\": 0.3,
      \"top_p\": 0.85,
      \"top_k\": 20,
      \"repeat_penalty\": 1.1,
      \"num_ctx\": 1024
    }
  }")

# Extraer respuesta
OLLAMA_RESPONSE=$(echo "$RESPONSE_RAW" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    print(data.get('response', ''))
except:
    print('')
" 2>/dev/null)

if [ -z "$OLLAMA_RESPONSE" ]; then
    echo -e "${RED}  ✗ Error: No se recibió respuesta de Ollama${RESET}"
    echo -e "${DIM}  Respuesta raw: ${RESPONSE_RAW:0:200}${RESET}"
    exit 1
fi

echo "$OLLAMA_RESPONSE" | fold -s -w 70 | sed 's/^/  /'
echo -e "${MAGENTA}└───────────────────────────────────────────────────${RESET}"
echo ""

# ── 7. Construir entrada HTML ─────────────────────────────────
echo -e "${BLUE}▶ Insertando entrada en ${DOCS_PATH}...${RESET}"

FILES_TAGS=""
IFS=',' read -ra FILES_ARR <<< "$COMMIT_FILES"
for f in "${FILES_ARR[@]}"; do
    f_trim=$(echo "$f" | xargs)
    [ -n "$f_trim" ] && FILES_TAGS+="<span class=\"file-tag\">${f_trim}</span>"
done

NEW_ENTRY="    <div class=\"entry\">
      <div class=\"entry-header\">
        <span class=\"commit-hash\">${COMMIT_HASH}</span>
        <span class=\"commit-title\">${COMMIT_MSG}</span>
      </div>
      <div class=\"commit-meta\">
        <span class=\"meta-item\">👤 Autor: <span>${COMMIT_AUTHOR}</span></span>
        <span class=\"meta-item\">📅 Fecha: <span>${COMMIT_DATE}</span></span>
        <span class=\"meta-item\">📊 <span>${COMMIT_STATS}</span></span>
      </div>
      <div class=\"entry-body\">
        <h3>📂 Archivos modificados</h3>
        <div class=\"files-list\">${FILES_TAGS}</div>
        <br>
        <h3>🤖 Análisis generado por phi3</h3>
        <div class=\"doc-content\">
          ${OLLAMA_RESPONSE}
        </div>
      </div>
    </div>"

# Reemplazar el empty-state si existe, o añadir antes de </div> del log-container
if grep -q "empty-state" "${DOCS_PATH}"; then
    # Eliminar el empty-state y añadir la entrada
    python3 - << PYEOF
import re

with open('${DOCS_PATH}', 'r', encoding='utf-8') as f:
    content = f.read()

# Eliminar empty-state
content = re.sub(r'\s*<div class="empty-state">.*?</div>', '', content, flags=re.DOTALL)

# Insertar nueva entrada al inicio del log-container
new_entry = """${NEW_ENTRY}"""
content = content.replace('<div id="log-container">', '<div id="log-container">\n' + new_entry)

with open('${DOCS_PATH}', 'w', encoding='utf-8') as f:
    f.write(content)

print("ok")
PYEOF
else
    # Añadir al inicio del log-container
    python3 - << PYEOF
import re

with open('${DOCS_PATH}', 'r', encoding='utf-8') as f:
    content = f.read()

new_entry = """${NEW_ENTRY}"""
content = content.replace('<div id="log-container">', '<div id="log-container">\n' + new_entry)

with open('${DOCS_PATH}', 'w', encoding='utf-8') as f:
    f.write(content)

print("ok")
PYEOF
fi

# Actualizar título del proyecto si es la primera vez
python3 - << PYEOF 2>/dev/null
with open('${DOCS_PATH}', 'r', encoding='utf-8') as f:
    content = f.read()

content = content.replace(
    '<h1 id="project-title">Documentación del Proyecto</h1>',
    '<h1 id="project-title">Documentación · ${PROJECT_NAME}</h1>'
)
content = content.replace(
    "document.getElementById('footer-date').textContent = new Date().toLocaleDateString('es-ES');",
    "document.getElementById('footer-date').textContent = new Date().toLocaleDateString('es-ES');"
)

with open('${DOCS_PATH}', 'w', encoding='utf-8') as f:
    f.write(content)
PYEOF

# Añadir el HTML al staging si no está tracked
git add "${DOCS_PATH}" 2>/dev/null

echo -e "${GREEN}  ✓ Documentación actualizada${RESET}"
echo ""

# ── 8. Resumen final ─────────────────────────────────────────
echo -e "${GREEN}${BOLD}╔══════════════════════════════════════════╗${RESET}"
echo -e "${GREEN}${BOLD}║  ✅  ¡Documentación generada con éxito!  ║${RESET}"
echo -e "${GREEN}${BOLD}╚══════════════════════════════════════════╝${RESET}"
echo ""
echo -e "  📄 Archivo: ${BOLD}${DOCS_PATH}${RESET}"
echo -e "  🔖 Commit:  ${BOLD}${COMMIT_HASH}${RESET} — ${COMMIT_MSG}"
echo -e "  🤖 Modelo:  ${BOLD}${OLLAMA_MODEL}${RESET}"
echo ""
