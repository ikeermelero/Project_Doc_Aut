    #log-container { display: flex; flex-direction: column; gap: 1.5rem; }

    .entry {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      transition: border-color 0.2s, transform 0.2s;
      animation: slideIn 0.4s ease both;
    }

    @keyframes slideIn {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .entry:hover { border-color: rgba(0,212,255,0.3); transform: translateY(-2px); }

    .entry-header {
      display: flex;
      align-items: center;
