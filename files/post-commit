#!/bin/bash

# ============================================================
#  git-ollama-docs — post-commit hook
#  Documenta automáticamente tus commits con Ollama phi3
# ============================================================

RESET="\033[0m"
BOLD="\033[1m"
DIM="\033[2m"
CYAN="\033[36m"
GREEN="\033[32m"
YELLOW="\033[33m"
RED="\033[31m"
BLUE="\033[34m"
MAGENTA="\033[35m"

OLLAMA_MODEL="phi3"
OLLAMA_URL="http://localhost:11434/api/generate"
DOCS_PATH="docs/DOCUMENTACION.html"

# ── Banner ──────────────────────────────────────────────────
echo ""
echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}${BOLD}║        🤖  git-ollama-docs               ║${RESET}"
echo -e "${CYAN}${BOLD}║   Documentación automática con Ollama    ║${RESET}"
echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════╝${RESET}"
echo ""

# ── 1. Recoger info del commit ───────────────────────────────
echo -e "${BLUE}▶ Leyendo información del commit...${RESET}"

COMMIT_HASH=$(git rev-parse --short HEAD)
COMMIT_MSG=$(git log -1 --pretty=%B | head -5)
COMMIT_AUTHOR=$(git log -1 --pretty="%an <%ae>")
COMMIT_DATE=$(git log -1 --pretty="%ad" --date=format:"%d/%m/%Y %H:%M")
COMMIT_FILES=$(git diff-tree --no-commit-id -r --name-only HEAD | head -20 | tr '\n' ', ' | sed 's/,$//')
COMMIT_STATS=$(git diff-tree --no-commit-id -r --stat HEAD | tail -1)
PROJECT_NAME=$(basename "$(git rev-parse --show-toplevel)")

echo -e "  ${DIM}Hash:${RESET}    ${BOLD}${COMMIT_HASH}${RESET}"
echo -e "  ${DIM}Autor:${RESET}   ${COMMIT_AUTHOR}"
echo -e "  ${DIM}Fecha:${RESET}   ${COMMIT_DATE}"
echo -e "  ${DIM}Mensaje:${RESET} ${COMMIT_MSG}"
echo -e "  ${DIM}Archivos:${RESET} ${COMMIT_FILES}"
echo ""

# ── 2. Preguntar al usuario ──────────────────────────────────
echo -e "${YELLOW}${BOLD}¿Deseas documentar este commit en ${DOCS_PATH}?${RESET}"
echo -e "${DIM}  [s] Sí, generar documentación   [n] No, salir${RESET}"
echo -ne "${CYAN}  → ${RESET}"
read -r RESPUESTA </dev/tty

if [[ ! "$RESPUESTA" =~ ^[sS]$ ]]; then
    echo -e "${DIM}  Saltando documentación. ¡Hasta el próximo commit!${RESET}"
    echo ""
    exit 0
fi

echo ""

# ── 3. Verificar que Ollama está activo ──────────────────────
echo -e "${BLUE}▶ Verificando conexión con Ollama (${OLLAMA_MODEL})...${RESET}"

if ! curl -s --max-time 3 "${OLLAMA_URL%/generate}" > /dev/null 2>&1; then
    echo -e "${RED}  ✗ No se puede conectar con Ollama en ${OLLAMA_URL}${RESET}"
    echo -e "${DIM}  Asegúrate de que Ollama está corriendo: ollama serve${RESET}"
    exit 1
fi

echo -e "${GREEN}  ✓ Ollama disponible${RESET}"
echo ""

# ── 4. Crear docs/ y DOCUMENTACION.html si no existen ───────
if [ ! -f "${DOCS_PATH}" ]; then
    echo -e "${BLUE}▶ Creando estructura docs/DOCUMENTACION.html...${RESET}"
    mkdir -p docs

    cat > "${DOCS_PATH}" << 'HTML_TEMPLATE'
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Documentación del Proyecto</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

