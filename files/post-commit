      flex-wrap: wrap;
    }

    .meta-item { font-size: 0.8rem; color: var(--muted); font-family: var(--mono); }
    .meta-item span { color: var(--text); }

    .entry-body { padding: 1.5rem; }

    .entry-body h3 {
